<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dose - Your Schedule"
        android:textColor="@color/widget_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_inner_bg"
        android:padding="12dp"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Missed"
            android:textColor="#FFB4AB"
            android:textSize="12sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/widget_missed_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No missed medicines"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_inner_bg"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upcoming"
            android:textColor="#D0BCFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_upcoming_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nothing scheduled"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>
</LinearLayout>
